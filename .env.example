# Copy to .env.local and fill in. Do not commit .env.local.

# Neon PostgreSQL – use POOLED for Vercel/serverless (host contains -pooler)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Optional: unpooled URL (no -pooler) for long-lived connections, e.g. migrations
# DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth (optional; for JWT verification if you use Neon Auth later)
# NEON_AUTH_URL=https://your-branch.neonauth.region.aws.neon.tech/neondb/auth
# NEON_AUTH_JWKS_URL=https://your-branch.neonauth.region.aws.neon.tech/neondb/auth/.well-known/jwks.json

# Session cookie (optional; dev default exists)
# SESSION_SECRET=your-secret
